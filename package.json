{
	"name": "ponto-up-frontend",
	"private": true,
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"type": "module",
	"scripts": {
		"dev": "npm run dev --workspaces",
		"build": "npm run build --workspaces",
		"check-types": "npm run check-types --workspaces",
		"dev:web": "npm run dev --workspace web",
		"check": "biome check --write .",
		"prepare": "husky"
	},
	"dependencies": {
		"@ponto-up-frontend/env": "*",
		"dotenv": "^17.2.2",
		"react-is": "^19.2.6",
		"zod": "^4.1.13"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.2.0",
		"@ponto-up-frontend/config": "*",
		"husky": "^9.1.7",
		"lint-staged": "^16.1.2",
		"typescript": "^6"
	},
	"lint-staged": {
		"*.{js,ts,cjs,mjs,d.cts,d.mts,jsx,tsx,json,jsonc}": [
			"biome check --write ."
		]
	},
	"packageManager": "npm@11.12.1"
}
